APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# Supabase Storage, accessed via its S3-compatible API: backs the "public" disk.
# AWS_ENDPOINT and AWS_URL are two DIFFERENT Supabase endpoints, don't merge them:
#   - AWS_ENDPOINT = the S3-compatible API used to upload/manage files (requires
#     signed requests: copy exactly what Supabase's S3 Connection panel shows you,
#     it may or may not include a "storage." subdomain depending on your project).
#   - AWS_URL = the plain public object REST endpoint used to actually view/download
#     a file in a browser (no signature needed). Without this set, Storage::url()
#     falls back to building a link from AWS_ENDPOINT instead, which will fail with
#     "AccessDenied: Missing signature" when opened directly.
# (Project Settings > Storage > S3 Connection in the Supabase dashboard)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=
AWS_BUCKET=
AWS_ENDPOINT=https://your-project-ref.supabase.co/storage/v1/s3
AWS_URL=https://your-project-ref.supabase.co/storage/v1/object/public/your-bucket-name
AWS_USE_PATH_STYLE_ENDPOINT=true

VITE_APP_NAME="${APP_NAME}"
